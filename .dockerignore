# Docker build context: only admin/, shared/, and root workspace files needed
# Everything else is excluded to minimise context size (~90% reduction)

# Version control
.git
.gitignore

# CI/CD and tooling
.github
.husky
.claude
.wrangler
coverage
plans

# Worker source (not needed for dashboard build)
src
test
drizzle
openapi
scripts

# Other packages (not needed for dashboard build)
mcp
slackbot

# Config files (not needed in build)
biome.json
oxlint.json
tsconfig.json
vitest.config.ts
drizzle.config.ts
wrangler.toml
wrangler.henrychong.toml
openapitools.json
.nvmrc

# Documentation (root *.md excluded except CHANGELOG.md which vite bundles)
*.md
!CHANGELOG.md

# Admin files not needed in any container stage — keeps the vite build cache
# from invalidating on Dockerfile/compose/lint-config edits. admin/nginx.conf
# and admin/scripts/ stay in context (stage-1 COPYs them).
admin/Dockerfile*
admin/docker-compose*.yml
admin/eslint.config.js
admin/vitest.config.ts
admin/README.md
admin/dist

# Shared build output — rebuilt inside the container
shared/dist

# OS files
.DS_Store
node_modules
