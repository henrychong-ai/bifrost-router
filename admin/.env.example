# Admin Dashboard Environment Variables

# API URL - the Bifrost admin API
VITE_API_URL=https://yourdomain.com

# Admin API Key - matches ADMIN_API_KEY secret on Worker
# In production (Docker): passed as ADMIN_API_KEY runtime env var, injected via env-config.js
# In local dev (pnpm dev): use VITE_ADMIN_API_KEY here (read as fallback in env.ts)
VITE_ADMIN_API_KEY=your-admin-api-key-here
